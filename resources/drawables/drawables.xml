<drawables xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">
    <bitmap id="LauncherIcon" filename="launcher_icon.svg" dithering="none" />
    <bitmap id="UploadIcon" filename="upload.png"/>
    <bitmap id="DiscardIcon" filename="trash.png"/>
    <bitmap id="SettingsIcon" filename="settings.png"/>
    <bitmap id="PlusIcon" filename="plus.png"/>

    <drawable-list id="BlueBackgroundBits">
        <!-- Light blue circle -->
        <shape type="circle" color="#ADD8E6" radius="10"/>

        <!-- Light blue rounded rectangle -->
        <shape type="rectangle" color="#ADD8E6" radius="10" />
    </drawable-list>
</drawables>